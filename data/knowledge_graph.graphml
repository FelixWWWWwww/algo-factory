  <graph edgedefault="directed">
    <node id="capability:failure_case_accuracy:Industrial_sensor_anomaly_detection">
      <data key="d0">Capability</data>
      <data key="d1">Industrial sensor anomaly detection</data>
      <data key="d2">在工业传感器数据上识别异常样本，适用于低标签或无标签场景。</data>
      <data key="d3">IsolationForest</data>
      <data key="d4">anomaly_detection</data>
      <data key="d5">industrial_sensors</data>
      <data key="d6">0.0</data>
    </node>
    <node id="algorithm:IsolationForest">
      <data key="d0">Algorithm</data>
      <data key="d1">IsolationForest</data>
      <data key="d2">IsolationForest algorithm</data>
      <data key="d7">["anomaly_detection"]</data>
    </node>
    <node id="metric:pr_auc">
      <data key="d0">Metric</data>
      <data key="d1">pr_auc</data>
      <data key="d2">用于评估极度不平衡异常检测任务的主指标。</data>
      <data key="d8">1.0</data>
      <data key="d9">0.6</data>
    </node>
    <node id="dependency:scikit-learn">
      <data key="d0">Dependency</data>
      <data key="d1">scikit-learn</data>
      <data key="d10">sklearn.ensemble.IsolationForest</data>
      <data key="d11">&gt;=1.0</data>
      <data key="d12">提供 IsolationForest 等核心异常检测实现。</data>
    </node>
    <node id="lesson:failure_case_accuracy:Always_use_PR-AUC_for_imbalanced_anomaly_detection">
      <data key="d0">Lesson</data>
      <data key="d13">Always use PR-AUC for imbalanced anomaly detection</data>
      <data key="d2">当异常样本占比很低时，PR-AUC 比 accuracy 更能反映模型效果。</data>
      <data key="d14">["all"]</data>
      <data key="d15">high</data>
      <data key="d16">failure_case_accuracy</data>
    </node>
    <node id="failure_case:using_accuracy_on_imbalanced_data">
      <data key="d0">FailureCase</data>
      <data key="d1">using accuracy on imbalanced data</data>
      <data key="d2">在极度不平衡数据上使用 accuracy 会掩盖异常样本的召回问题。</data>
      <data key="d17">accuracy 受正常样本主导，无法反映异常检测效果。</data>
      <data key="d18">anomaly ratio &lt; 5%</data>
      <data key="d19">high</data>
      <data key="d20">改用 PR-AUC、Recall 和 F1 作为主指标。</data>
      <data key="d16">ocsvm_tuning</data>
    </node>
    <node id="lesson:using_accuracy_on_imbalanced_data:mitigation">
      <data key="d0">Lesson</data>
      <data key="d13">Avoid: using accuracy on imbalanced data</data>
      <data key="d2">改用 PR-AUC、Recall 和 F1 作为主指标。</data>
      <data key="d14">["all"]</data>
      <data key="d15">high</data>
      <data key="d16">ocsvm_tuning</data>
    </node>
