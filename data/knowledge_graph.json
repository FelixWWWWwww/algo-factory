    "metric:pr_auc": {
      "type": "Metric",
      "name": "pr_auc",
      "description": "用于评估极度不平衡异常检测任务的主指标。",
      "ideal_value": 1.0,
      "min_threshold": 0.6
    },
    "dependency:scikit-learn": {
      "type": "Dependency",
      "name": "scikit-learn",
